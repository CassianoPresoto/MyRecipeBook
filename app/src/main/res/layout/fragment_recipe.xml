<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_m">

        <ImageView
            android:id="@+id/image"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            tools:src="@android:color/darker_gray" />

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_m"
            android:textStyle="bold"
            android:textSize="@dimen/title_text_size"
            tools:text="Classic Margherita Pizza" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_s"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/rating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/description_text_size"
                app:drawableStartCompat="@drawable/star_ic"
                android:drawablePadding="@dimen/padding_xs"
                android:tint="?attr/colorSecondary"
                tools:text="4.8" />

            <TextView
                android:id="@+id/time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_m"
                android:textSize="@dimen/description_text_size"
                tools:text="35 min" />

            <TextView
                android:id="@+id/servings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_m"
                android:textSize="@dimen/description_text_size"
                tools:text="Servings: 4" />

            <TextView
                android:id="@+id/difficulty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_m"
                android:textSize="@dimen/description_text_size"
                tools:text="Difficulty: Easy" />
        </LinearLayout>

        <TextView
            android:id="@+id/tags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_s"
            android:textSize="@dimen/small_text_size"
            android:textColor="@android:color/darker_gray"
            tools:text="#Italian  #Dinner" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_l"
            android:textStyle="bold"
            android:textSize="@dimen/title_text_size"
            android:text="Ingredients" />

        <TextView
            android:id="@+id/ingredients"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_s"
            android:textSize="@dimen/description_text_size"
            tools:text="- Tomato\n- Mozzarella\n- Basil" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_l"
            android:textStyle="bold"
            android:textSize="@dimen/title_text_size"
            android:text="Instructions" />

        <TextView
            android:id="@+id/instructions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_s"
            android:textSize="@dimen/description_text_size"
            tools:text="1. Preheat oven\n\n2. Spread sauce\n\n3. Bake" />

    </LinearLayout>
</ScrollView>
